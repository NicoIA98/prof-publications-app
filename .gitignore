# =========================
# File e cartelle da NON versionare con Git
# per mantenere la repository pulita e portabile
# =========================

# Output generato da Maven
target/

# File e cartelle locali di IntelliJ IDEA
.idea/
*.iml

# File temporanei / specifici del sistema operativo
.DS_Store
Thumbs.db

# =========================
# Configurazione locale e credenziali
# =========================

# File .env locale con credenziali reali
.env
*.env
!.env.example

# Settings locali salvati dall'app nella home utente
# Esempio reale:
# C:\Users\<utente>\.prof-publications-app\settings.properties
settings.properties

# Eventuale cartella locale dell'app se venisse creata per errore dentro il progetto
.prof-publications-app/

# =========================
# Database SQLite locale generato dall'app
# =========================

prof-publications.db
*.db
*.db-journal
*.sqlite
*.sqlite3
*.sqlite-journal